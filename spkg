#!/bin/bash

if [[ $EUID -ne 0 ]]; then
    echo "spkg requires sudo. Try: sudo spkg $*"
    exit 1
fi

cmd_search() {
    local app=$1
    if [[ -z "$app" ]]; then
        echo "Usage: sudo spkg search <app>"
        exit 1
    fi

    echo "==> Search results for '$app':"
    echo ""

    local counter=1

    # Pacman results
    while IFS= read -r pkg; do
        local version
        version=$(pacman -Si "$pkg" 2>/dev/null | grep "^Version" | awk '{print $3}' | head -n1)
        printf " [%d] %-35s v%-20s [pacman]\n" "$counter" "$pkg" "$version"
        ((counter++))
    done < <(pacman -Ssq "$app" 2>/dev/null)

    # AUR results
    while IFS= read -r pkg; do
        local version
        version=$(paru -Si "$pkg" 2>/dev/null | grep "^Version" | awk '{print $3}' | head -n1)
        printf " [%d] %-35s v%-20s [aur]\n" "$counter" "$pkg" "$version"
        ((counter++))
    done < <(paru -Ssq --aur "$app" 2>/dev/null | grep -v "^::")

    # Flatpak results
    while IFS= read -r pkg; do
        [[ -z "$pkg" || "$pkg" == "Application ID" ]] && continue
        local version
        version=$(flatpak search --columns=version "$pkg" 2>/dev/null | tail -n +2 | head -n1)
        printf " [%d] %-35s v%-20s [flatpak]\n" "$counter" "$pkg" "$version"
        ((counter++))
    done < <(flatpak search --columns=application "$app" 2>/dev/null | tail -n +2)

    if [[ $counter -eq 1 ]]; then
        echo " No results found for '$app'."
    fi
}

cmd_install() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: sudo spkg install <app> [app2] [app3]..."
        exit 1
    fi

    for app in "$@"; do
        echo ""
        echo "==> Searching for '$app'..."

        # Try exact match first
        mapfile -t pacman_results < <(pacman -Ssq "^${app}$" 2>/dev/null)
        mapfile -t aur_results < <(paru -Ssq --aur "^${app}$" 2>/dev/null | grep -v "^::")
        mapfile -t flatpak_results < <(flatpak search --columns=application "$app" 2>/dev/null | tail -n +2 | grep -i "^${app}$")

        # Fall back to broad search if nothing found
        if [[ ${#pacman_results[@]} -eq 0 && ${#aur_results[@]} -eq 0 && ${#flatpak_results[@]} -eq 0 ]]; then
            mapfile -t pacman_results < <(pacman -Ssq "$app" 2>/dev/null)
            mapfile -t aur_results < <(paru -Ssq --aur "$app" 2>/dev/null | grep -v "^::")
            mapfile -t flatpak_results < <(flatpak search --columns=application "$app" 2>/dev/null | tail -n +2)
        fi

        declare -a all_results
        declare -a all_sources
        for pkg in "${pacman_results[@]}"; do
            all_results+=("$pkg")
            all_sources+=("pacman")
        done
        for pkg in "${aur_results[@]}"; do
            all_results+=("$pkg")
            all_sources+=("aur")
        done
        for pkg in "${flatpak_results[@]}"; do
            all_results+=("$pkg")
            all_sources+=("flatpak")
        done

        local total=${#all_results[@]}

        if [[ $total -eq 0 ]]; then
            echo "No results found for '$app', skipping."
            continue
        elif [[ $total -eq 1 ]]; then
            echo "Found: ${all_results[0]} [${all_sources[0]}]"
            echo "Installing..."
            _do_install "${all_results[0]}" "${all_sources[0]}"
        else
            echo "Multiple results found:"
            echo ""
            for i in "${!all_results[@]}"; do
                printf " [%d] %-35s [%s]\n" "$((i+1))" "${all_results[$i]}" "${all_sources[$i]}"
            done
            read -rp "Enter number to install (or 0 to skip): " choice
            if [[ $choice -eq 0 ]]; then
                echo "Skipping '$app'."
                continue
            fi
            local idx=$((choice-1))
            _do_install "${all_results[$idx]}" "${all_sources[$idx]}"
        fi

        unset all_results all_sources
    done
}

_do_install() {
    local pkg=$1
    local source=$2
    case "$source" in
        pacman)  pacman -S "$pkg" ;;
        aur)     sudo -u "$SUDO_USER" paru -S "$pkg" ;;
        flatpak) sudo -u "$SUDO_USER" flatpak install "$pkg" ;;
    esac
}

cmd_remove() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: sudo spkg remove <app> [app2] [app3]..."
        exit 1
    fi

    for app in "$@"; do
        echo ""
        echo "==> Searching for installed package '$app'..."

        if pacman -Qq "$app" &>/dev/null; then
            pacman -R "$app"
        elif flatpak list --columns=application | grep -q "$app"; then
            flatpak uninstall "$app"
        else
            echo "Package '$app' not found in pacman or Flatpak, skipping."
            echo "If it was installed via AUR, try: paru -R $app"
            continue
        fi
    done
}

cmd_update() {
    if [[ $# -eq 0 ]]; then
        echo "Usage: sudo spkg update <app>/all [app2] [app3]..."
        exit 1
    fi

    if [[ "$1" == "all" ]]; then
        echo "==> Updating all pacman & AUR packages..."
        paru -Syu

        echo ""
        echo "==> Updating all Flatpak packages..."
        flatpak update
    else
        for app in "$@"; do
            echo ""
            echo "==> Updating '$app'..."

            if pacman -Qq "$app" &>/dev/null; then
                paru -S "$app"
            elif flatpak list --columns=application | grep -q "$app"; then
                flatpak update "$app"
            else
                echo "Package '$app' not found, skipping."
                continue
            fi
        done
    fi
}

ACTION=$1
APP=$2

case "$ACTION" in
    install) shift; cmd_install "$@" ;;
    remove)  shift; cmd_remove "$@" ;;
    update)  shift; cmd_update "$@" ;;
    search)  cmd_search "$APP" ;;
    *)
        echo "Usage: sudo spkg install/remove/update/search <app>"
        echo "       sudo spkg update all"
        exit 1
        ;;
esac
